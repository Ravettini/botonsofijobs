# Webhook n8n (servidor)
N8N_WEBHOOK_URL=

# Token para validar /api/run
RUN_TOKEN_SERVER=

# Token que envía el front (mismo valor que RUN_TOKEN_SERVER)
NEXT_PUBLIC_RUN_TOKEN=

# Carpeta de Drive: link y nombre para el recordatorio en la UI
# Si no hay URL, no se muestra el botón "Abrir carpeta"
NEXT_PUBLIC_DRIVE_FOLDER_URL=
NEXT_PUBLIC_DRIVE_FOLDER_NAME=
